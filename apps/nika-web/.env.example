# Variáveis de ambiente do nika-web
# Copie para .env.local e preencha com seus valores reais
# NUNCA commite .env.local no Git

# ─── Supabase ────────────────────────────────────────────────────────────────
# Obtidos no dashboard: https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ─── App ─────────────────────────────────────────────────────────────────────
# URL base do app (necessário para redirecionamentos de auth)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Ambiente ────────────────────────────────────────────────────────────────
# Não precisa preencher manualmente – Vercel injeta automaticamente
# VERCEL_ENV=development|preview|production
